<div class="max-w-lg mx-auto">
  <h1 class="text-2xl font-bold mb-6">地図の更新設定</h1>

  <div class="bg-white shadow-md rounded-lg p-6">
    <div class="mb-4">
      <h2 class="text-lg font-semibold text-gray-700">現在の設定</h2>
      <p class="text-gray-900 mt-1" id="current-refresh-mode">
        <%= @map_setting.refresh_mode_i18n %>
      </p>
    </div>

    <div class="flex justify-end">
      <%= link_to '設定を変更する', edit_admin_map_setting_path, class: "bg-blue-500 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded" %>
    </div>
  </div>
</div>
